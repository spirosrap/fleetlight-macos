{
  "version": 1,
  "hosts": [
    {
      "id": "local",
      "displayName": "This Mac",
      "systemImage": "laptopcomputer",
      "isLocal": true,
      "codexDesktopApp": true
    },
    {
      "id": "home-server",
      "displayName": "Home Server",
      "systemImage": "server.rack",
      "linuxUpdates": true,
      "services": ["tailscale", "docker"],
      "wakeMACAddress": "00:11:22:33:44:55",
      "wakeBroadcastAddress": "192.0.2.255",
      "routes": [
        { "alias": "home-server", "displayName": "Direct" },
        { "alias": "home-server-lan", "displayName": "Local network" }
      ]
    }
  ]
}
